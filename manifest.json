{
  "manifest_version": 3,
  "name": "标签页助手",
  "version": "1.0",
  "description": "允许用户自定义新标签页跳转地址",

  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },

  "options_page": "options.html",
  "host_permissions": ["<all_urls>"],
  "permissions": ["storage", "tabs"],
  "action": {
    "default_title": "打开设置"
  },
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}